{
  "name": "tik-test",
  "version": "0.1.0",
  "description": "TikTok-style automated video testing for UI feature reviews.",
  "bin": {
    "tik-test": "dist/cli.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "viewer": "node dist/viewer.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "playwright": "^1.49.0",
    "chalk": "^5.3.0",
    "yaml": "^2.6.0",
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "keywords": ["testing", "video", "playwright", "claude", "e2e", "ui-review"],
  "license": "MIT"
}
