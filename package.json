{
  "name": "tik-test",
  "version": "0.1.0",
  "description": "TikTok-style automated video testing for UI feature reviews.",
  "bin": {
    "tik-test": "dist/cli.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "viewer": "node dist/viewer.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@playwright/mcp": "^0.0.70",
    "@remotion/bundler": "^4.0.451",
    "@remotion/cli": "^4.0.451",
    "@remotion/media": "^4.0.451",
    "@remotion/media-utils": "^4.0.451",
    "@remotion/renderer": "^4.0.451",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "playwright": "^1.49.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "remotion": "^4.0.451",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "keywords": [
    "testing",
    "video",
    "playwright",
    "claude",
    "e2e",
    "ui-review"
  ],
  "license": "MIT"
}
