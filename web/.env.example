# ---------------------------------------------------------------------------
# REQUIRED — normal GitHub OAuth login
# ---------------------------------------------------------------------------

# GitHub OAuth app — register at https://github.com/settings/applications/new
# Homepage URL: https://<your-deployment>.example.com
# Authorization callback URL: https://<your-deployment>.example.com/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Any 32+ byte random string. `openssl rand -base64 32`
AUTH_SECRET=

# Optional — only needed for custom domains; Vercel auto-detects otherwise.
# NEXTAUTH_URL=https://<your-deployment>.example.com

# ---------------------------------------------------------------------------
# OPTIONAL — test-mode auth bypass (for tik-test self-review CI)
#
# Lets the tik-test-webapp.yml workflow log in to the deployed reviewer via a
# signed time-bound URL. See web/src/lib/bypass.ts for the threat model.
# Leave blank in normal deployments — the route returns 404 unless ALL three
# *_BYPASS_* vars + AUTH_SECRET are populated.
# ---------------------------------------------------------------------------

# 32-byte hex secret used to HMAC the signed bypass URL. `openssl rand -hex 32`.
# Must match the GitHub Actions secret `TIKTEST_BYPASS_SECRET` exactly.
TIKTEST_BYPASS_SECRET=

# Fine-grained PAT scoped to the ONE repo under test, READ-ONLY on
# Contents / Metadata / Pull requests. Worst-case blast radius if leaked =
# read public PR data on that one repo. See web/README.md for setup.
TIKTEST_BYPASS_GH_TOKEN=

# GitHub username the bypass session impersonates. Shown as the session
# `login` and stamped onto the JWT `sub` claim.
TIKTEST_BYPASS_GH_LOGIN=

# Kill switch — set to "1" (or any truthy value) to disable the bypass route
# instantly with no redeploy. Unset / "0" = enabled (subject to other checks).
# TIKTEST_BYPASS_DISABLED=0

# Optional — clock-skew tolerance in seconds for the signed URL `ts` param.
# Defaults to 60. Clamped to [5, 300]. Wider windows = larger replay window.
# TIKTEST_BYPASS_MAX_SKEW_S=60
