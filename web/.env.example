# GitHub OAuth app — register at https://github.com/settings/applications/new
# Homepage URL: https://<your-vercel-url>
# Authorization callback URL: https://<your-vercel-url>/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Any 32+ byte random string. `openssl rand -base64 32`
AUTH_SECRET=

# Optional — defaults to your Vercel deployment URL, but set explicitly if you use a custom domain.
# NEXTAUTH_URL=https://tik-test-review.vercel.app
